{
  "extends": "../../packages/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022", "ES2020", "ES2019", "ES2018", "ES2017", "ES2016", "ES2015", "DOM", "WebWorker"],
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}