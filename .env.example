# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787

# Clerk (get from Clerk Dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json

# Cloudflare D1 Database (get from Cloudflare Dashboard → Workers & Pages → D1)
CF_D1_DATABASE_ID=your-database-id
CF_D1_DATABASE_NAME=reviewflow-db

# Cloudflare R2 Storage (get from Cloudflare Dashboard → R2)
CF_R2_BUCKET_NAME=reviewflow-assets
CF_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Cloudflare Workers/Pages (get from Cloudflare Dashboard)
CF_ACCOUNT_ID=your-account-id
CF_ZONE_ID=your-zone-id
CF_API_TOKEN=your-api-token

# Google Business Profile API (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# Encryption key for Google tokens (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Twilio (SMS) - get from Twilio Console
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_MESSAGING_SERVICE_SID=MG...
TWILIO_WEBHOOK_SECRET=...

# Resend (Email) - get from Resend Dashboard
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=...
RESEND_FROM_EMAIL=reviews@yourdomain.com

# Stripe (get from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_AGENCY=price_...

# Optional Integrations
SENTRY_DSN=https://...
LOGTAIL_SOURCE_TOKEN=...