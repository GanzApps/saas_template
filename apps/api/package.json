{
  "name": "@saas/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --local --persist",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy --env production",
    "deploy:preview": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "hono": "catalog:",
    "@hono/clerk-auth": "catalog:",
    "@hono/zod-validator": "catalog:",
    "@saas/config": "*",
    "@saas/db-d1": "*",
    "@saas/google": "*",
    "@saas/communications": "*",
    "@saas/storage": "*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@saas/tsconfig": "*",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "wrangler": "catalog:"
  }
}