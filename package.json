{
  "name": "saas-mvp",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "db:push": "turbo run db:push",
    "db:types": "turbo run db:types",
    "db:studio": "turbo run db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@turbo/gen": "^1.13.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}